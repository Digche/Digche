NODE_ENV=development
PORT=3003

DB_HOST=chat-db
DB_PORT=5432
DB_NAME=chat_db
DB_USER=chat_user
DB_PASSWORD=chat_password

# Must exactly match auth-service JWT_SECRET.
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_32_chars

AUTH_INTERNAL_BASE_URL=http://auth-service:3001
AUTH_INTERNAL_API_KEY=change_me_internal_auth_key
AUTH_PROFILE_RESOLVE_TIMEOUT_MS=3000
AUTH_TOKEN_VERIFY_TIMEOUT_MS=3000

CHAT_MESSAGE_MAX_LENGTH=2000
CHAT_HISTORY_DEFAULT_LIMIT=30
CHAT_HISTORY_MAX_LIMIT=100

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_SWAGGER=true

LOG_LEVEL=info
LOG_PRETTY=true
