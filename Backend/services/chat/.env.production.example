NODE_ENV=production
PORT=3003

DB_HOST=chat-db
DB_PORT=5432
DB_NAME=chat_db
DB_USER=chat_user
DB_PASSWORD=replace_with_same_value_as_CHAT_DB_PASSWORD

JWT_SECRET=replace_with_same_64_hex_secret_in_all_services

AUTH_INTERNAL_BASE_URL=http://auth-service:3001
AUTH_INTERNAL_API_KEY=replace_with_same_value_as_auth_service
AUTH_PROFILE_RESOLVE_TIMEOUT_MS=3000
AUTH_TOKEN_VERIFY_TIMEOUT_MS=3000

CHAT_MESSAGE_MAX_LENGTH=2000
CHAT_HISTORY_DEFAULT_LIMIT=30
CHAT_HISTORY_MAX_LIMIT=100

CORS_ORIGINS=https://digche.ir,https://www.digche.ir
ENABLE_SWAGGER=false

LOG_LEVEL=info
LOG_PRETTY=false
