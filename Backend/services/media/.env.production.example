NODE_ENV=production
PORT=3002

JWT_SECRET=replace_with_same_64_hex_secret_in_all_services

AUTH_INTERNAL_BASE_URL=http://auth-service:3001
AUTH_INTERNAL_API_KEY=replace_with_same_value_as_auth_service
AUTH_TOKEN_VERIFY_TIMEOUT_MS=3000

MEDIA_INTERNAL_API_KEY=replace_with_strong_internal_media_key

ARVAN_REGION=default
ARVAN_ENDPOINT=https://YOUR_ARVAN_S3_ENDPOINT
ARVAN_ACCESS_KEY=replace_with_arvan_access_key
ARVAN_SECRET_KEY=replace_with_arvan_secret_key
ARVAN_BUCKET=replace_with_bucket_name
ARVAN_PUBLIC_BASE_URL=https://cdn.example.com
ARVAN_FORCE_PATH_STYLE=true
ARVAN_DEFAULT_ACL=public-read

MEDIA_PRESIGN_EXPIRES_SECONDS=600
MEDIA_PROFILE_MAX_SIZE_BYTES=5242880
MEDIA_DISH_MAX_SIZE_BYTES=10485760

CORS_ORIGINS=https://digche.ir,https://www.digche.ir
ENABLE_SWAGGER=false

LOG_LEVEL=info
