NODE_ENV=development
PORT=3002

# باید دقیقا همان JWT_SECRET سرویس auth باشد تا media-service بتواند access tokenها را verify کند.
JWT_SECRET=change_me_in_real_env

# کلید داخلی برای درخواست‌های service-to-service از core یا سرویس‌های آینده.
# مقدار واقعی را در .env بگذار، نه در Git.
MEDIA_INTERNAL_API_KEY=change_me_internal_media_key

# Arvan Object Storage / S3-compatible config
# مقدارهای واقعی پروژه خودت را اینجا در فایل .env قرار بده.
ARVAN_REGION=default
ARVAN_ENDPOINT=https://YOUR_ARVAN_S3_ENDPOINT
ARVAN_ACCESS_KEY=YOUR_ARVAN_ACCESS_KEY
ARVAN_SECRET_KEY=YOUR_ARVAN_SECRET_KEY
ARVAN_BUCKET=YOUR_BUCKET_NAME

# اگر CDN یا دامنه public اختصاصی داری این را پر کن.
# مثال الگو: https://YOUR_BUCKET_NAME.YOUR_ARVAN_S3_HOST
ARVAN_PUBLIC_BASE_URL=

# برای Arvan معمولا true مناسب است.
ARVAN_FORCE_PATH_STYLE=true

# اگر policy باکت اجازه public-read نمی‌دهد، این مقدار را خالی کن یا مطابق policy خودت تنظیم کن.
ARVAN_DEFAULT_ACL=public-read

MEDIA_PRESIGN_EXPIRES_SECONDS=600
MEDIA_PROFILE_MAX_SIZE_BYTES=5242880
MEDIA_DISH_MAX_SIZE_BYTES=10485760

LOG_LEVEL=info
