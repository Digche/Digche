NODE_ENV=production
PORT=3004

DB_HOST=ticket-db
DB_PORT=5432
DB_NAME=ticket_db
DB_USER=ticket_user
DB_PASSWORD=replace_with_same_value_as_TICKET_DB_PASSWORD

JWT_SECRET=replace_with_same_64_hex_secret_in_all_services

AUTH_INTERNAL_BASE_URL=http://auth-service:3001
AUTH_INTERNAL_API_KEY=replace_with_same_value_as_auth_service
AUTH_TOKEN_VERIFY_TIMEOUT_MS=3000

CORS_ORIGINS=https://digche.ir,https://www.digche.ir
ENABLE_SWAGGER=false

LOG_LEVEL=info
LOG_PRETTY=false
