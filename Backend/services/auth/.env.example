NODE_ENV=development
PORT=3001

DB_HOST=auth-db
DB_PORT=5432
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_password

JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_32_chars
OTP_EXPIRES_MINUTES=2
OTP_RATE_LIMIT_PER_HOUR=5

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

INITIAL_MANAGER_PHONE=09031241172
AUTH_INTERNAL_API_KEY=change_me_internal_auth_key

REGISTRATION_TOKEN_EXPIRES_IN=10m
REGISTRATION_TOKEN_EXPIRES_MINUTES=10

# Comma-separated allowed origins for profile photo URLs.
# Leave empty in local development if you need to accept any http/https URL.
AUTH_ALLOWED_PHOTO_URL_ORIGINS=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_SWAGGER=true


OTP_PROVIDER=dev

KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=

# OTP_PROVIDER=kavenegar
# KAVENEGAR_API_KEY=your_real_api_key
# KAVENEGAR_TEMPLATE=your_verify_template_name


CACHE_PROVIDER=redis

REDIS_HOST=auth-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=auth:

OTP_COOLDOWN_SECONDS=60


LOG_LEVEL=info
LOG_PRETTY=true
