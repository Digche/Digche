NODE_ENV=development
PORT=3001

DB_HOST=auth-db
DB_PORT=5432
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_password

JWT_SECRET=change_me_in_real_env
OTP_EXPIRES_MINUTES=2
OTP_RATE_LIMIT_PER_HOUR=5

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

INITIAL_MANAGER_PHONE=09031241172
AUTH_INTERNAL_API_KEY=change_me_internal_auth_key

REGISTRATION_TOKEN_EXPIRES_IN=10m


OTP_PROVIDER=dev

KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=

# OTP_PROVIDER=kavenegar
# KAVENEGAR_API_KEY=your_real_api_key
# KAVENEGAR_TEMPLATE=your_verify_template_name


CACHE_PROVIDER=redis

REDIS_HOST=auth-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=auth:

OTP_COOLDOWN_SECONDS=60


LOG_LEVEL=info
LOG_PRETTY=true
