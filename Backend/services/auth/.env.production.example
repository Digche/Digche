NODE_ENV=production
PORT=3001

DB_HOST=auth-db
DB_PORT=5432
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=replace_with_same_value_as_AUTH_DB_PASSWORD

JWT_SECRET=replace_with_same_64_hex_secret_in_all_services
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
REGISTRATION_TOKEN_EXPIRES_IN=10m
REGISTRATION_TOKEN_EXPIRES_MINUTES=10

INITIAL_MANAGER_PHONE=09xxxxxxxxx
AUTH_INTERNAL_API_KEY=replace_with_strong_internal_auth_key

OTP_PROVIDER=kavenegar
OTP_EXPIRES_MINUTES=2
OTP_RATE_LIMIT_PER_HOUR=5
OTP_COOLDOWN_SECONDS=60
KAVENEGAR_API_KEY=replace_with_kavenegar_api_key
KAVENEGAR_TEMPLATE=replace_with_kavenegar_template

CACHE_PROVIDER=redis
REDIS_HOST=auth-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=auth:

AUTH_ALLOWED_PHOTO_URL_ORIGINS=https://cdn.example.com
CORS_ORIGINS=https://digche.ir,https://www.digche.ir
ENABLE_SWAGGER=false

LOG_LEVEL=info
LOG_PRETTY=false
